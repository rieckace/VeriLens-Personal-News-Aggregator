# Server
PORT=5000
# Comma-separated list supported, e.g. http://localhost:5173,http://localhost:5174
CLIENT_ORIGIN=http://localhost:5173

# Mongo
MONGO_URI=mongodb://127.0.0.1:27017/ai_news_aggregator

# Auth
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# News API (NewsAPI.org)
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_DEFAULT_COUNTRY=us
NEWS_FETCH_INTERVAL_CRON=*/30 * * * *
ENABLE_SCHEDULED_FETCH=true
